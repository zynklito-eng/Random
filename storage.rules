rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /chat_attachments/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'zynklito@gmail.com');
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }
  }
}
