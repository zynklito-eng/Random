{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile, representing either a buyer or the admin.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A premium account or subscription listed for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "subscriptionName": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "Sold Out"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "description", "subscriptionName", "price", "status", "createdAt", "updatedAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A one-on-one chat thread between a user and the admin.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "lastMessage": { "type": "string" }
      },
      "required": ["userId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A specific message inside a conversation.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["senderId", "createdAt"]
    },
    "AdminStatus": {
      "title": "AdminStatus",
      "description": "Global status reflecting if admin is online or offline.",
      "type": "object",
      "properties": {
        "isOnline": { "type": "boolean" },
        "updatedAt": { "type": "number" }
      },
      "required": ["isOnline", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores products listed by admin."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Stores chat threads."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores individual chat messages."
    },
    "/status/{statusId}": {
      "schema": { "$ref": "#/entities/AdminStatus" },
      "description": "Stores global admin presence status. specifically 'admin_status'."
    }
  }
}
